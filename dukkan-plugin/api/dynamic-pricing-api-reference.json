{
  "base_url": "https://fashion.dukkanjo.com/wp-json/dukkan-dynamic-pricing/v1",
  "auth": "none (public)",

  "endpoints": {
    "list_rules":           "GET    /rules?page=1&per_page=10&search=keyword",
    "get_rule":             "GET    /rules/{uid}",
    "create_rule":          "POST   /rules",
    "update_rule":          "PUT    /rules/{uid}",
    "delete_rule":          "DELETE /rules/{uid}",
    "search_products":      "GET    /products/search?search=shirt&per_page=10"
  },

  "pricing_methods": [
    { "key": "discount__amount",     "meaning": "Fixed discount",    "example": "$10 off each item" },
    { "key": "discount__percentage", "meaning": "Percentage discount","example": "15% off" },
    { "key": "fee__amount",          "meaning": "Fixed fee",         "example": "$5 added per item" },
    { "key": "fee__percentage",      "meaning": "Percentage fee",    "example": "10% added" },
    { "key": "fixed__price",         "meaning": "Fixed price",       "example": "Set price to $49.99" }
  ],

  "product_method": [
    { "key": "in_list",     "meaning": "Rule applies to items in the list" },
    { "key": "not_in_list", "meaning": "Rule applies to items NOT in the list" }
  ],

  "product_category_method": [
    { "key": "in_list",     "meaning": "Rule applies to categories in the list" },
    { "key": "not_in_list", "meaning": "Rule applies to categories NOT in the list" }
  ],

  "cart_conditions": {
    "description": "Array of condition objects. Each has type, method_option, and value.",
    "types": [
      { "type": "cart_subtotal", "meaning": "Cart subtotal amount",   "value_type": "decimal" },
      { "type": "cart_quantity", "meaning": "Total quantity in cart",  "value_type": "decimal" },
      { "type": "cart_count",    "meaning": "Distinct items in cart",  "value_type": "number" },
      { "type": "cart_weight",   "meaning": "Total cart weight",       "value_type": "decimal" }
    ],
    "operators": [
      { "key": "at_least",      "meaning": ">= (greater than or equal)" },
      { "key": "more_than",     "meaning": "> (greater than)" },
      { "key": "not_more_than", "meaning": "<= (less than or equal)" },
      { "key": "less_than",     "meaning": "< (less than)" }
    ]
  },

  "rule_fields": {
    "uid":                      { "type": "string",  "required": "auto", "desc": "Unique ID, e.g. rp_wcdpd_abc123" },
    "note":                     { "type": "string",  "required": "no",   "desc": "Private admin note" },
    "public_note":              { "type": "string",  "required": "no",   "desc": "Public description shown to customer" },
    "pricing_method":           { "type": "string",  "required": "YES",  "desc": "See pricing_methods table above" },
    "pricing_value":            { "type": "number",  "required": "YES",  "desc": "Positive number. 10 = $10 or 10%" },
    "product_uids":             { "type": "[int]",   "required": "YES*", "desc": "Array of product IDs. *Required unless product_category_uids is set" },
    "product_method":           { "type": "string",  "required": "no",   "desc": "in_list (default) or not_in_list" },
    "product_category_uids":    { "type": "[int]",   "required": "YES*", "desc": "Array of category IDs. *Required unless product_uids is set" },
    "product_category_method":  { "type": "string",  "required": "no",   "desc": "in_list (default) or not_in_list" },
    "conditions":               { "type": "[object]","required": "no",   "desc": "Cart conditions. See cart_conditions table above" }
  },

  "examples": {
    "by_product": {
      "desc": "20% discount on products 40289 and 40372",
      "method": "POST /rules",
      "body": {
        "note": "Summer sale",
        "pricing_method": "discount__percentage",
        "pricing_value": 20,
        "product_uids": [40289, 40372],
        "product_method": "in_list"
      }
    },
    "by_category": {
      "desc": "$5 discount on all SKIRT category products",
      "method": "POST /rules",
      "body": {
        "note": "Skirt discount",
        "pricing_method": "discount__amount",
        "pricing_value": 5,
        "product_category_uids": [1811],
        "product_category_method": "in_list"
      }
    },
    "with_cart_condition": {
      "desc": "$10 off product 40289 when cart subtotal >= $100",
      "method": "POST /rules",
      "body": {
        "pricing_method": "discount__amount",
        "pricing_value": 10,
        "product_uids": [40289],
        "product_method": "in_list",
        "conditions": [
          { "type": "cart_subtotal", "method_option": "at_least", "value": 100 }
        ]
      }
    },
    "with_two_conditions": {
      "desc": "20% off when subtotal >= $50 AND cart weight < 5",
      "method": "POST /rules",
      "body": {
        "pricing_method": "discount__percentage",
        "pricing_value": 20,
        "product_uids": [40289],
        "product_method": "in_list",
        "conditions": [
          { "type": "cart_subtotal", "method_option": "at_least", "value": 50 },
          { "type": "cart_weight",   "method_option": "less_than", "value": 5 }
        ]
      }
    },
    "update": {
      "desc": "Change discount from 30% to 40%",
      "method": "PUT /rules/rp_wcdpd_44f5e892",
      "note": "Partial update. Only send fields you want to change",
      "body": {
        "pricing_value": 40
      }
    },
    "delete": {
      "desc": "Delete a rule",
      "method": "DELETE /rules/rp_wcdpd_abc123"
    }
  }
}
